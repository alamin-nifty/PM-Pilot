# Leave these unset to run on built-in sample data (USE_FIXTURES defaults on).
# Set USE_FIXTURES=false to disable the sample data once real tokens are in.

# Slack (read-only scopes: channels:history, groups:history, users:read)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_IDS=        # comma-separated channel ids

# ClickUp (read-only)
CLICKUP_API_TOKEN=
CLICKUP_FOLDER_ID=   # folder containing all sprints (set once)
CLICKUP_LIST_ID=     # the active sprint list (change each sprint via Settings)

USE_FIXTURES=
